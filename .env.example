# Variáveis de ambiente — Pitombo Lanches
# Copie este arquivo para .env e preencha com seus valores reais

# Porta do servidor
PORT=3000

# Conexão com PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/pitombo_lanches

# Secret para geração de JWT (tokens de autenticação admin)
JWT_SECRET=pitombo_secret_mude_em_producao

# Ambiente
NODE_ENV=development
